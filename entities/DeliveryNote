{
  "name": "DeliveryNote",
  "type": "object",
  "properties": {
    "delivery_number": {
      "type": "string",
      "description": "Num\u00e9ro de bon de livraison"
    },
    "customer_id": {
      "type": "string",
      "description": "ID du client"
    },
    "customer_name": {
      "type": "string",
      "description": "Nom du client"
    },
    "order_id": {
      "type": "string",
      "description": "ID de la commande d'origine"
    },
    "order_number": {
      "type": "string",
      "description": "Num\u00e9ro de commande"
    },
    "delivery_date": {
      "type": "string",
      "format": "date",
      "description": "Date de livraison"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "sent",
        "invoiced"
      ],
      "default": "draft",
      "description": "Statut du BL"
    },
    "items": {
      "type": "array",
      "description": "Lignes du bon de livraison",
      "items": {
        "type": "object",
        "properties": {
          "manufacturing_order_id": {
            "type": "string"
          },
          "order_number": {
            "type": "string"
          },
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "product_reference": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "total": {
            "type": "number"
          }
        }
      }
    },
    "delivery_address": {
      "type": "string",
      "description": "Adresse de livraison"
    },
    "notes": {
      "type": "string",
      "description": "Notes"
    },
    "invoice_id": {
      "type": "string",
      "description": "ID de la facture associ\u00e9e"
    }
  },
  "required": [
    "delivery_number",
    "customer_id",
    "customer_name"
  ]
}