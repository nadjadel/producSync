{
  "name": "Invoice",
  "type": "object",
  "properties": {
    "invoice_number": {
      "type": "string",
      "description": "Num\u00e9ro de facture"
    },
    "invoice_date": {
      "type": "string",
      "format": "date",
      "description": "Date de facture"
    },
    "customer_id": {
      "type": "string",
      "description": "ID du client"
    },
    "customer_name": {
      "type": "string",
      "description": "Nom du client"
    },
    "customer_address": {
      "type": "string",
      "description": "Adresse du client"
    },
    "customer_siret": {
      "type": "string",
      "description": "SIRET du client"
    },
    "customer_vat_number": {
      "type": "string",
      "description": "N\u00b0 TVA du client"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "sent",
        "paid",
        "overdue",
        "cancelled"
      ],
      "default": "draft",
      "description": "Statut de la facture"
    },
    "payment_terms": {
      "type": "string",
      "description": "Conditions de paiement"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Date d'\u00e9ch\u00e9ance"
    },
    "delivery_notes": {
      "type": "array",
      "description": "Bons de livraison inclus",
      "items": {
        "type": "object",
        "properties": {
          "delivery_note_id": {
            "type": "string"
          },
          "delivery_number": {
            "type": "string"
          },
          "delivery_date": {
            "type": "string"
          }
        }
      }
    },
    "items": {
      "type": "array",
      "description": "Lignes de facture",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "total_ht": {
            "type": "number"
          },
          "vat_rate": {
            "type": "number"
          }
        }
      }
    },
    "total_ht": {
      "type": "number",
      "description": "Total HT"
    },
    "total_vat": {
      "type": "number",
      "description": "Total TVA"
    },
    "total_ttc": {
      "type": "number",
      "description": "Total TTC"
    },
    "notes": {
      "type": "string",
      "description": "Notes"
    },
    "payment_date": {
      "type": "string",
      "format": "date",
      "description": "Date de paiement"
    }
  },
  "required": [
    "invoice_number",
    "customer_id",
    "customer_name"
  ]
}