{
  "name": "Quote",
  "type": "object",
  "properties": {
    "quote_number": {
      "type": "string",
      "description": "Num\u00e9ro de devis (DE + 8 chiffres)"
    },
    "quote_date": {
      "type": "string",
      "format": "date",
      "description": "Date du devis"
    },
    "customer_id": {
      "type": "string",
      "description": "ID du client"
    },
    "customer_name": {
      "type": "string",
      "description": "Nom du client"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "sent",
        "accepted",
        "rejected",
        "expired"
      ],
      "default": "draft",
      "description": "Statut du devis"
    },
    "valid_until": {
      "type": "string",
      "format": "date",
      "description": "Valide jusqu'au"
    },
    "items": {
      "type": "array",
      "description": "Lignes du devis",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "product_reference": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "total": {
            "type": "number"
          }
        }
      }
    },
    "total_ht": {
      "type": "number",
      "description": "Total HT"
    },
    "vat_rate": {
      "type": "number",
      "default": 20,
      "description": "Taux de TVA (%)"
    },
    "total_vat": {
      "type": "number",
      "description": "Montant TVA"
    },
    "total_ttc": {
      "type": "number",
      "description": "Total TTC"
    },
    "notes": {
      "type": "string",
      "description": "Notes"
    },
    "order_id": {
      "type": "string",
      "description": "ID de la commande si accept\u00e9"
    }
  },
  "required": [
    "quote_number",
    "customer_id",
    "customer_name"
  ]
}