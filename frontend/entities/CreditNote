{
  "name": "CreditNote",
  "type": "object",
  "properties": {
    "credit_note_number": {
      "type": "string",
      "description": "Num\u00e9ro d'avoir (AV + 8 chiffres)"
    },
    "credit_note_date": {
      "type": "string",
      "format": "date",
      "description": "Date de l'avoir"
    },
    "customer_id": {
      "type": "string",
      "description": "ID du client"
    },
    "customer_name": {
      "type": "string",
      "description": "Nom du client"
    },
    "invoice_id": {
      "type": "string",
      "description": "ID de la facture d'origine"
    },
    "invoice_number": {
      "type": "string",
      "description": "Num\u00e9ro de facture d'origine"
    },
    "reason": {
      "type": "string",
      "description": "Motif de l'avoir"
    },
    "items": {
      "type": "array",
      "description": "Lignes de l'avoir",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "total_ht": {
            "type": "number"
          },
          "vat_rate": {
            "type": "number"
          }
        }
      }
    },
    "total_ht": {
      "type": "number",
      "description": "Total HT"
    },
    "total_vat": {
      "type": "number",
      "description": "Total TVA"
    },
    "total_ttc": {
      "type": "number",
      "description": "Total TTC"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "sent",
        "applied"
      ],
      "default": "draft",
      "description": "Statut de l'avoir"
    }
  },
  "required": [
    "credit_note_number",
    "customer_id",
    "customer_name"
  ]
}